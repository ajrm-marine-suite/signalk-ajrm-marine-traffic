{
  "openapi": "3.0.3",
  "info": {
    "title": "AJRM Marine AJRM Marine Traffic API",
    "version": "0.5.11",
    "description": "Authoritative AJRM Marine Traffic capability, target, Auto Profile, Audio Policy, and command projections."
  },
  "servers": [
    {
      "url": "/plugins/signalk-ajrm-marine-traffic"
    }
  ],
  "paths": {
    "/status": {
      "get": {
        "summary": "Get AJRM Marine Traffic capability, target and policy projections",
        "responses": {
          "200": {
            "description": "Current AJRM Marine Traffic capability, target, and policy state"
          }
        }
      }
    },
    "/commands": {
      "get": {
        "summary": "Get AJRM Marine Traffic command capability and runtime state",
        "responses": {
          "200": {
            "description": "Current command state"
          }
        }
      }
    },
    "/commands/profile": {
      "put": {
        "summary": "Select the authoritative AJRM Marine Traffic profile",
        "responses": {
          "200": {
            "description": "Profile selected"
          }
        }
      }
    },
    "/commands/profiles": {
      "get": {
        "summary": "Get AJRM Marine Traffic profile sensitivity settings",
        "responses": {
          "200": {
            "description": "Current per-profile sensitivity settings"
          }
        }
      },
      "put": {
        "summary": "Update AJRM Marine Traffic profile sensitivity settings",
        "responses": {
          "200": {
            "description": "Profile sensitivity settings saved"
          }
        }
      }
    },
    "/commands/targets/{identity}/silence": {
      "post": {
        "summary": "Silence or unsilence one AJRM Marine Traffic target",
        "parameters": [
          {
            "name": "identity",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Target silence state changed"
          },
          "404": {
            "description": "Target not found"
          }
        }
      }
    },
    "/commands/unsilence-all": {
      "post": {
        "summary": "Clear all runtime target silence state",
        "responses": {
          "200": {
            "description": "Targets unsilenced"
          }
        }
      }
    }
  }
}
